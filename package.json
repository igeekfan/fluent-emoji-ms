{
  "name": "fluent-emoji-ms-workspace",
  "version": "0.1.0",
  "description": "Workspace for Fluent Emoji multi-platform packages and demo",
  "author": "igeekfan",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:packages && pnpm run build:web",
    "build:packages": "pnpm -r --filter @igeekfan/fluent-emoji-ms-core --filter @igeekfan/fluent-emoji-ms-vue --filter @igeekfan/fluent-emoji-ms-react --filter @igeekfan/fluent-emoji-ms-svelte build",
    "build:lib": "pnpm --filter @igeekfan/fluent-emoji-ms-vue build",
    "build:web": "vite build --mode web",
    "test:core": "pnpm --filter @igeekfan/fluent-emoji-ms-core test",
    "preview": "vite preview",
    "generate-emoji-list": "node scripts/generate-emoji-list.js"
  },
  "dependencies": {
    "@igeekfan/fluent-emoji-ms-vue": "workspace:*",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "typescript": "^5.1.6",
    "vite": "^4.4.8",
    "vite-plugin-dts": "^3.0.3",
    "vue-tsc": "^1.8.8"
  },
  "keywords": [
    "emoji",
    "vue",
    "microsoft",
    "fluent",
    "fluent-ui",
    "fluent-emoji",
    "fluent-emoji-picker",
    "emoji-picker",
    "fluent-emoji-ms"
  ]
}
